            "content": "<!DOCTYPE html>\r\n<html lang=\"ru\">\r\n<head>\r\n  <meta charset=\"UTF-8\">\r\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\r\n  <title>Settings</title>\r\n  <link rel=\"stylesheet\" href=\"options.css\">\r\n</head>\r\n<body>\r\n  <div class=\"settings-container\">\r\n    <header class=\"settings-header\">\r\n      <h1><img src=\"../icons/logo-green16.png\"> Settings </h1>\r\n    </header>\r\n\r\n    <div class=\"status-box\">\r\n      <div id=\"proxyStatus\" class=\"status-indicator\"></div>\r\n      <span id=\"proxyStatusText\">Checking proxy status...</span>\r\n    </div>\r\n\r\n    <main class=\"settings-main\">\r\n    <div class=\"section\">\r\n      <h3>Proxy Server</h3>\r\n      <div class=\"input-group\">\r\n        <input type=\"text\" id=\"proxyHost\" placeholder=\"Proxy address (e.g. 127.0.0.1)\">\r\n        <input type=\"number\" id=\"proxyPort\" placeholder=\"Port (e.g. 8080)\">\r\n      </div>\r\n    </div>\r\n      <hr>\r\n      \r\n      <div class=\"section\">\r\n        <h3>Domains</h3>\r\n        <div class=\"domain-controls\">\r\n          <input type=\"text\" id=\"domainInput\" placeholder=\"Add domain (e.g. example.com)\">\r\n          <button id=\"addDomainBtn\" class=\"icon-btn\">+ Add</button>\r\n        </div>\r\n        <ul id=\"domainsList\" class=\"domains-list\"></ul>\r\n      </div>\r\n      \r\n      <div class=\"section\" style=\"display: none;\">\r\n        <!-- <h3>Related Domains</h3> -->\r\n        <div id=\"relatedDomainsAccordion\"> \r\n          <!-- class=\"accordion\" -->\r\n          <!-- <div class=\"accordion-header\"> -->\r\n            <span>Related domains  </span>\r\n            <button id=\"toggleRelatedBtn\">▼</button>\r\n          <!-- </div> -->\r\n          <div id=\"relatedDomainsList\" class=\"accordion-content\"></div>\r\n        </div>\r\n      </div>\r\n      \r\n      <button id=\"saveBtn\" class=\"save-btn\">Save Settings</button>\r\n      <div id=\"statusMessage\"></div>\r\n    </main>\r\n\r\n  </div>\r\n  <script src=\"options.js\"></script>\r\n</body>\r\n</html>"
